APP_NAME=MindBridge Learn
APP_VERSION=0.9.0
ENVIRONMENT=development
LOG_LEVEL=INFO

SERVER_HOST=127.0.0.1
SERVER_PORT=8000

DATABASE_URL=sqlite:///./data/mindbridge.db

# 此 SQLite 文件只保存可丢弃的本地学习数据。
# Schema 变化后需要由开发者手工确认并重建；create_all 不是迁移工具。

# 克隆、自动测试和 CI 保持安全的离线默认值。
# 只有本机四层 readiness 全部通过后，才在私有 .env 中改为 ollama。
AI_PROVIDER=mock
AI_TEMPERATURE=0.0
AI_MAX_TOKENS=512
AI_CONNECT_TIMEOUT_SECONDS=5.0
AI_READ_TIMEOUT_SECONDS=60.0
AI_TOTAL_TIMEOUT_SECONDS=120.0

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=mindbridge-qwen2.5-7b-ft:latest

FINETUNED_MODEL_DIR=models/mindbridge-qwen2.5-7b-ft
FINETUNED_MODEL_FILE=mindbridge-qwen2.5-7b-ft-q4_k_m.gguf

# 只有把 AI_PROVIDER 改成 openai_compatible 时才填写下面三项。
# OPENAI_COMPATIBLE_BASE_URL=https://example.com/v1
# OPENAI_COMPATIBLE_API_KEY=replace-with-private-api-key
# OPENAI_COMPATIBLE_MODEL=replace-with-model-name

BOOTSTRAP_STUDENT_USERNAME=student
BOOTSTRAP_STUDENT_DISPLAY_NAME=Student
# BOOTSTRAP_STUDENT_PASSWORD=replace-with-private-password

BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_DISPLAY_NAME=Administrator
# BOOTSTRAP_ADMIN_PASSWORD=replace-with-private-password
