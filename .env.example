APP_NAME=MindBridge Learn
APP_VERSION=0.7.0
ENVIRONMENT=development
LOG_LEVEL=INFO

SERVER_HOST=127.0.0.1
SERVER_PORT=8000

DATABASE_URL=sqlite:///./data/mindbridge.db

# 此 SQLite 文件只保存可丢弃的本地学习数据。
# Schema 变化后需要由开发者手工确认并重建；create_all 不是迁移工具。

AI_PROVIDER=mock
AI_TEMPERATURE=0.0
AI_MAX_TOKENS=512

BOOTSTRAP_STUDENT_USERNAME=student
BOOTSTRAP_STUDENT_DISPLAY_NAME=Student
# BOOTSTRAP_STUDENT_PASSWORD=replace-with-private-password

BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_DISPLAY_NAME=Administrator
# BOOTSTRAP_ADMIN_PASSWORD=replace-with-private-password
